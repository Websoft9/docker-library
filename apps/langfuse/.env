# Langfuse on Docker - Environment Configuration
# Edit this file to customize the deployment settings.
# Full documentation: https://langfuse.com/docs/deployment/docker

# =========================================================
# Image
# version tags refer to: https://hub.docker.com/r/langfuse/langfuse/tags
# =========================================================
W9_REPO=langfuse/langfuse
W9_DIST='community'
W9_VERSION='3'
W9_WORKER_REPO=langfuse/langfuse-worker
W9_WORKER_VERSION='3'

# =========================================================
# Authentication & Security
# W9_POWER_PASSWORD: Unified password for all services (Postgres, ClickHouse, Redis, MinIO)
# W9_KEY_SET: Secret for NextAuth session encryption
# W9_RCODE: Base value for encryption key (will be doubled to 64 chars)
# =========================================================
W9_POWER_PASSWORD='#I^QLLgrLeXfLgJL'
W9_KEY_SET='ws89V6lzPFVcuzlrOVHQ1mXvDMLl9t7r'
W9_RCODE='5e7802212ed209a94f0ccd7502e01485'

# =========================================================
# Ports & User Settings
# W9_HTTP_PORT_SET: External web access port (default: 9001)
# W9_MINIO_PORT_SET: MinIO console port (default: 9090)
# =========================================================
W9_HTTP_PORT_SET='9001'
W9_MINIO_PORT_SET='9090'

#### --  Not allowed to edit below environments when recreate app based on existing data  -- ####

# =========================================================
# System (managed by Websoft9, do not modify)
# =========================================================
W9_ID='langfuse'
W9_NETWORK='websoft9'
W9_HTTP_PORT='3000'
W9_DB_EXPOSE='postgresql'
W9_URL='internet_ip:$W9_HTTP_PORT_SET'
W9_URL_REPLACE='true'

#### --------------------------------------------------------------------------------------- ####

# =========================================================
# PostgreSQL Configuration
# Official image reference: https://hub.docker.com/_/postgres
# =========================================================
POSTGRES_USER='postgres'
POSTGRES_PASSWORD=$W9_POWER_PASSWORD
POSTGRES_DB='postgres'
POSTGRES_VERSION='17'

# =========================================================
# ClickHouse Configuration
# Official image reference: https://hub.docker.com/r/clickhouse/clickhouse-server
# =========================================================
CLICKHOUSE_USER='clickhouse'
CLICKHOUSE_PASSWORD=$W9_POWER_PASSWORD

# =========================================================
# Redis Configuration
# Official image reference: https://hub.docker.com/_/redis
# =========================================================
REDIS_AUTH=$W9_POWER_PASSWORD

# =========================================================
# MinIO (S3-compatible) Configuration
# Official image reference: https://hub.docker.com/r/minio/minio
# =========================================================
MINIO_ROOT_USER='minio'
MINIO_ROOT_PASSWORD=$W9_POWER_PASSWORD

# =========================================================
# Langfuse Application Configuration
# Official environment variable reference: https://langfuse.com/docs/deployment/self-host
# =========================================================

# NextAuth - Authentication & Session Management
NEXTAUTH_URL=$W9_URL
NEXTAUTH_SECRET=$W9_KEY_SET
SALT=$W9_POWER_PASSWORD
ENCRYPTION_KEY=${W9_RCODE}${W9_RCODE}

# Database Connection URLs
DATABASE_URL=postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@$W9_ID-postgres:5432/$POSTGRES_DB
CLICKHOUSE_MIGRATION_URL=clickhouse://$W9_ID-clickhouse:9000
CLICKHOUSE_URL=http://$W9_ID-clickhouse:8123

# Redis Connection
REDIS_HOST=$W9_ID-redis
REDIS_PORT='6379'

# S3 Storage - Event Upload (Internal MinIO)
LANGFUSE_S3_EVENT_UPLOAD_BUCKET='langfuse'
LANGFUSE_S3_EVENT_UPLOAD_REGION='auto'
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=$MINIO_ROOT_USER
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=$MINIO_ROOT_PASSWORD
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://$W9_ID-minio:9000
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE='true'
LANGFUSE_S3_EVENT_UPLOAD_PREFIX='events/'

# S3 Storage - Media Upload (External Access via Host Port)
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET='langfuse'
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=$MINIO_ROOT_USER
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=$MINIO_ROOT_PASSWORD
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://localhost:$W9_MINIO_PORT_SET
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE='true'

# S3 Storage - Batch Export (Disabled by default)
LANGFUSE_S3_BATCH_EXPORT_ENABLED='false'

# Telemetry & Experimental Features
TELEMETRY_ENABLED='true'
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES='false'