# Databasus on Docker - Environment Configuration
# Edit this file to customize the deployment settings.
# Full documentation: https://databasus.com/installation

# =========================================================
# Image
# version tags refer to: https://hub.docker.com/r/databasus/databasus/tags
# =========================================================
W9_REPO='databasus/databasus'
W9_DIST='community'
W9_VERSION='v3.16.3'

# =========================================================
# Ports
# W9_HTTP_PORT_SET: host port mapped to the container's web UI
# Dashboard: http://localhost:$W9_HTTP_PORT_SET
# =========================================================
W9_HTTP_PORT_SET='9001'

#### --  Not allowed to edit below environments when recreate app based on existing data  -- ####

# =========================================================
# System (managed by Websoft9, do not modify)
# =========================================================
W9_ID='databasus'
W9_HTTP_PORT=4005
W9_URL='internet_ip:$W9_HTTP_PORT_SET'
W9_NETWORK=websoft9

#### ----------------------------------------------------------------------------------------- ####
# Below environment is created by this app
# refer to: https://databasus.com/installation
