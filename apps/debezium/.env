# Debezium Server on Docker - Environment Configuration
# Edit this file to customize the deployment settings.
# Full documentation: https://debezium.io/documentation/reference/stable/operations/debezium-server.html
# Source connector and sink are configured in: src/application.properties

# =========================================================
# Image
# version tags refer to: https://hub.docker.com/r/debezium/server/tags
# =========================================================
W9_REPO=debezium/server
W9_DIST='community'
W9_VERSION='3.4'

# =========================================================
# Ports
# W9_HTTP_PORT_SET: host port mapped to the container's Quarkus HTTP server
# Health check endpoint: http://localhost:$W9_HTTP_PORT_SET/q/health
# =========================================================
W9_HTTP_PORT_SET='9001'
# W9_HTTPS_PORT_SET='9443'   # Uncomment if HTTPS termination is needed

#### --  Not allowed to edit below environments when recreate app based on existing data  -- ####

# =========================================================
# System (managed by Websoft9, do not modify)
# =========================================================
W9_ID='debezium'
# Internal Quarkus HTTP port — must match quarkus.http.port in application.properties
W9_HTTP_PORT=8080
W9_URL='internet_ip:$W9_HTTP_PORT_SET'
W9_NETWORK=websoft9