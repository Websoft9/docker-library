# Concrete CMS on Docker - Environment Configuration
# Edit this file to customize the deployment settings.
# Full documentation: https://documentation.concretecms.org

# =========================================================
# Image
# version tags refer to: https://hub.docker.com/_/php
# =========================================================
W9_REPO=php
W9_DIST='community'
W9_VERSION='8.2-apache'

# =========================================================
# Authentication
# Initial administrator credentials for first login
# =========================================================
W9_POWER_PASSWORD='Concrete#Pass2026!'

# =========================================================
# Ports & User Settings
# W9_xxx_xxx_SET — user can modify when creating app
# =========================================================
W9_HTTP_PORT_SET='9001'

#### --  Not allowed to edit below environments when recreate app based on existing data  -- ####

# =========================================================
# System (managed by Websoft9, do not modify)
# =========================================================
W9_ID='concrete'
W9_HTTP_PORT=80
W9_LOGIN_USER=admin@example.com
W9_LOGIN_PASSWORD=$W9_POWER_PASSWORD
W9_ADMIN_PATH="/index.php/dashboard"
W9_DB_EXPOSE="mysql"
W9_DB_VERSION="8.0"
W9_URL=internet_ip:$W9_HTTP_PORT_SET
W9_URL_REPLACE=true
W9_NETWORK=websoft9
#### --------------------------------------------------------------------------------------- ####

# =========================================================
# Application-specific settings
# Official environment variable reference: https://documentation.concretecms.org
# =========================================================

# Concrete CMS installation parameters
CONCRETE_DB_SERVER=$W9_ID-mysql
CONCRETE_DB_NAME=$W9_ID
CONCRETE_DB_USER=$W9_ID
CONCRETE_DB_PASSWORD=$W9_POWER_PASSWORD

CONCRETE_ADMIN_EMAIL=$W9_LOGIN_USER
CONCRETE_ADMIN_PASSWORD=$W9_LOGIN_PASSWORD
CONCRETE_CANONICAL_URL=http://$W9_URL
CONCRETE_STARTING_POINT=atomik_full

# MySQL Configuration
MYSQL_DATABASE=$W9_ID
MYSQL_USER=$W9_ID
MYSQL_PASSWORD=$W9_POWER_PASSWORD
MYSQL_ROOT_PASSWORD=$W9_POWER_PASSWORD
